# Stripe (live) — get from dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=rk_live_REPLACE_ME
STRIPE_PUBLISHABLE_KEY=pk_live_REPLACE_ME

# Stripe prices — get from dashboard.stripe.com → Products
STRIPE_PRICE_ID=price_REPLACE_ME_MONTHLY
STRIPE_ANNUAL_PRICE_ID=price_REPLACE_ME_ANNUAL

# Stripe webhook — set this after creating webhook endpoint in Stripe dashboard
# Endpoint URL: https://myfreemoney.app/api/stripe/webhook
# Events: checkout.session.completed, customer.subscription.deleted,
#         customer.subscription.updated, customer.subscription.paused,
#         customer.subscription.resumed, invoice.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# App settings
FREEMONEY_BASE_URL=https://myfreemoney.app
FREEMONEY_ENV=prod
ADMIN_EMAIL=info@myfreemoney.app

# DB path — Railway Volume should mount at /data
DB_PATH=/data/settlements.db

# SMTP (Google Workspace) for restore-code emails — get app password from accounts.google.com → Security
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=info@myfreemoney.app
SMTP_PASS=REPLACE_ME_WORKSPACE_APP_PASSWORD
SMTP_FROM=info@myfreemoney.app
